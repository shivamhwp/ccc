---
import "@fontsource-variable/geist";
import "@fontsource-variable/geist-mono";

const commands: [string, string][] = [
  ["ccc setup", "Wire up Claude Code: import your current login, start the proxy daemon, install the agent skill."],
  ["ccc login <name>", "Add another account via browser sign-in, saved under <name>."],
  ["ccc list", "List saved accounts."],
  ["ccc use <name>", "Route the current thread to <name> — live, no restart."],
  ["ccc use --default", "Revert the current thread to the default account."],
  ["ccc whoami", "Show which account the current thread is using."],
  ["ccc default <name>", "Set the fallback account for threads with no explicit route."],
  ["ccc remove <name>", "Remove a saved account."],
  ["ccc t3 sync", "Add one t3code provider per account (ccc t3 unsync to remove)."],
  ["ccc doctor", "Diagnostics: verify the daemon, settings, and auth."],
  ["ccc daemon start | stop | status", "Control the local proxy daemon."],
  ["ccc teardown", "Undo ccc setup."],
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>ccc</title>
    <meta name="description" content="use two or more claude accounts on your device." />
  </head>
  <body>
    <section class="hero">
      <h1>ccc</h1>
      <span class="scroll">↓</span>
    </section>

    <main class="docs">
      <h2>commands</h2>
      <dl>
        {commands.map(([cmd, desc]) => (
          <div class="row">
            <dt><code>{cmd}</code></dt>
            <dd>{desc}</dd>
          </div>
        ))}
      </dl>
    </main>

    <style is:global>
      :root {
        --fg: #000;
        --bg: #fff;
        --muted: #666;
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; }
      body {
        background: var(--bg);
        color: var(--fg);
        font-family: "Geist Variable", system-ui, sans-serif;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      .hero {
        height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 2rem;
      }
      .hero h1 {
        font-size: clamp(5rem, 22vw, 16rem);
        font-weight: 600;
        letter-spacing: -0.04em;
        line-height: 1;
      }
      .scroll {
        font-size: 1.25rem;
        color: var(--muted);
        animation: bob 1.8s ease-in-out infinite;
      }
      @keyframes bob {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(6px); }
      }

      .docs {
        max-width: 720px;
        margin: 0 auto;
        padding: 6rem 1.5rem 8rem;
      }
      .docs h2 {
        font-size: 1rem;
        font-weight: 500;
        color: var(--muted);
        text-transform: lowercase;
        margin-bottom: 2.5rem;
      }
      dl { display: flex; flex-direction: column; }
      .row {
        padding: 1.1rem 0;
        border-top: 1px solid #ececec;
      }
      dt {
        font-family: "Geist Mono Variable", ui-monospace, monospace;
        font-size: 0.95rem;
        font-weight: 500;
        margin-bottom: 0.35rem;
      }
      dd {
        font-size: 0.95rem;
        line-height: 1.5;
        color: var(--muted);
      }

      @media (prefers-reduced-motion: reduce) {
        .scroll { animation: none; }
        html { scroll-behavior: auto; }
      }
    </style>
  </body>
</html>
