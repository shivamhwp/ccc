---
import "@fontsource/micro-5";
import "@fontsource-variable/geist-mono";

const INSTALL = "curl -fsSL https://raw.githubusercontent.com/shivamhwp/ccc/main/scripts/install.sh | bash";

const commands: [string, string][] = [
  ["ccc setup", "Wire up Claude Code: import your current login, start the proxy daemon, install the agent skill."],
  ["ccc login <name>", "Add another account via browser sign-in, saved under <name>."],
  ["ccc list", "List saved accounts."],
  ["ccc use <name>", "Route the current thread to <name> — live, no restart."],
  ["ccc use --default", "Revert the current thread to the default account."],
  ["ccc whoami", "Show which account the current thread is using."],
  ["ccc default <name>", "Set the fallback account for threads with no explicit route."],
  ["ccc remove <name>", "Remove a saved account."],
  ["ccc t3 sync", "Add one t3code provider per account (ccc t3 unsync to remove)."],
  ["ccc doctor", "Diagnostics: verify the daemon, settings, and auth."],
  ["ccc daemon start | stop | status", "Control the local proxy daemon."],
  ["ccc teardown", "Undo ccc setup."],
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>ccc</title>
    <meta name="description" content="use two or more claude accounts on your device." />
  </head>
  <body>
    <div class="wrap">
      <header class="top">
        <h1 class="logo">ccc</h1>
        <button class="copy" data-cmd={INSTALL} aria-label="Copy install command">copy</button>
      </header>

      <dl class="commands">
        {commands.map(([cmd, desc]) => (
          <div class="row">
            <dt><code>{cmd}</code></dt>
            <dd>{desc}</dd>
          </div>
        ))}
      </dl>
    </div>

    <style is:global>
      :root { --fg: #000; --bg: #fff; --muted: #666; --line: #ececec; }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        background: var(--bg);
        color: var(--fg);
        font-family: "Geist Mono Variable", ui-monospace, monospace;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      .wrap {
        max-width: 56rem; /* max-w-4xl */
        margin: 0 auto;
        padding: 4rem 1.5rem 6rem;
      }

      .top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 3.5rem;
      }
      .logo {
        font-family: "Micro 5", "Geist Mono Variable", monospace;
        font-weight: 400;
        font-size: clamp(3.5rem, 9vw, 6rem);
        line-height: 0.9;
        letter-spacing: 0.02em;
      }

      .copy {
        font-family: inherit;
        font-size: 0.85rem;
        color: var(--fg);
        background: transparent;
        border: 1px solid var(--fg);
        border-radius: 6px;
        padding: 0.45rem 0.9rem;
        cursor: pointer;
        transition: background 0.15s ease, color 0.15s ease;
      }
      .copy:hover { background: var(--fg); color: var(--bg); }
      .copy.copied { background: var(--fg); color: var(--bg); }

      .commands { display: flex; flex-direction: column; }
      .row { padding: 1rem 0; border-top: 1px solid var(--line); }
      dt { font-size: 0.9rem; font-weight: 500; margin-bottom: 0.35rem; }
      dd { font-size: 0.9rem; line-height: 1.55; color: var(--muted); }
    </style>

    <script>
      const btn = document.querySelector<HTMLButtonElement>(".copy");
      btn?.addEventListener("click", async () => {
        const cmd = btn.dataset.cmd ?? "";
        try {
          await navigator.clipboard.writeText(cmd);
          const prev = btn.textContent;
          btn.textContent = "copied";
          btn.classList.add("copied");
          setTimeout(() => {
            btn.textContent = prev;
            btn.classList.remove("copied");
          }, 1400);
        } catch {
          /* clipboard unavailable */
        }
      });
    </script>
  </body>
</html>
