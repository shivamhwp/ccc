---
import "@fontsource/micro-5";
import "@fontsource-variable/geist-mono";

const commands: [string, string][] = [
  ["ccc setup", "Wire up Claude Code: import your login, start the daemon, install the skill."],
  ["ccc login <name>", "Add another account via browser sign-in, saved under <name>."],
  ["ccc list", "List saved accounts."],
  ["ccc use <name>", "Route the current thread to <name> — live, no restart."],
  ["ccc use --default", "Revert the current thread to the default account."],
  ["ccc whoami", "Show which account the current thread is using."],
  ["ccc default <name>", "Set the fallback account for unrouted threads."],
  ["ccc remove <name>", "Remove a saved account."],
  ["ccc t3 sync", "Add one t3code provider per account (unsync to remove)."],
  ["ccc doctor", "Diagnostics: verify the daemon, settings, and auth."],
  ["ccc daemon start | stop | status", "Control the local proxy daemon."],
  ["ccc teardown", "Undo ccc setup."],
];

// Plain-text version of the page that the "copy page" button copies.
const pageText = [
  "ccc — use two or more claude accounts on your device",
  "",
  ...commands.map(([cmd, desc]) => `${cmd} — ${desc}`),
  "",
  "https://github.com/shivamhwp/ccc",
].join("\n");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>ccc</title>
    <meta name="description" content="use two or more claude accounts on your device." />
    <link
      rel="icon"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3E%3Crect width='16' height='16' fill='%23000'/%3E%3C/svg%3E"
    />
  </head>
  <body>
    <div class="wrap">
      <header class="top">
        <h1 class="logo">ccc</h1>
        <div class="actions">
          <button class="copy" data-copy={pageText} aria-label="Copy page">copy page</button>
          <a class="gh" href="https://github.com/shivamhwp/ccc" target="_blank" rel="noopener noreferrer">gh</a>
        </div>
      </header>

      <dl class="commands">
        {commands.map(([cmd, desc]) => (
          <div class="row">
            <dt><code>{cmd}</code></dt>
            <dd>{desc}</dd>
          </div>
        ))}
      </dl>
    </div>

    <style is:global>
      :root { --fg: #000; --bg: #fff; --muted: #666; --line: #ececec; }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      html, body {
        height: 100%;
        overscroll-behavior: none; /* no rubber-band bounce */
      }
      body {
        background: var(--bg);
        color: var(--fg);
        font-family: "Geist Mono Variable", ui-monospace, monospace;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
        overflow: hidden; /* everything fits — no scrollbar */
      }

      .wrap {
        max-width: 56rem; /* max-w-4xl */
        margin: 0 auto;
        padding: 2.25rem 1.5rem;
      }

      .top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.5rem;
      }
      .logo {
        font-family: "Micro 5", "Geist Mono Variable", monospace;
        font-weight: 400;
        font-size: clamp(2.5rem, 6vw, 3.25rem);
        line-height: 1;
        letter-spacing: 0.02em;
      }

      .actions { display: flex; align-items: center; gap: 1rem; }
      .copy {
        font-family: inherit;
        font-size: 0.8rem;
        color: var(--fg);
        background: transparent;
        border: 1px solid var(--fg);
        border-radius: 6px;
        padding: 0.4rem 0.85rem;
        cursor: pointer;
        transition: background 0.15s ease, color 0.15s ease;
      }
      .copy:hover, .copy.copied { background: var(--fg); color: var(--bg); }
      .gh {
        font-family: inherit;
        font-size: 0.8rem;
        color: var(--fg);
        text-decoration: none;
        border-bottom: 1px solid transparent;
      }
      .gh:hover { border-bottom-color: var(--fg); }

      .commands { display: flex; flex-direction: column; }
      .row {
        display: grid;
        grid-template-columns: 18rem 1fr;
        gap: 2.5rem;
        align-items: baseline;
        padding: 0.5rem 0;
        border-top: 1px solid var(--line);
      }
      dt { font-size: 0.82rem; font-weight: 500; white-space: nowrap; }
      dd { font-size: 0.82rem; line-height: 1.4; color: var(--muted); }

      @media (max-width: 640px) {
        body { overflow: auto; }
        .row { grid-template-columns: 1fr; gap: 0.25rem; }
        dt { white-space: normal; }
      }
    </style>

    <script>
      const btn = document.querySelector(".copy");
      btn?.addEventListener("click", async () => {
        const text = btn.getAttribute("data-copy") ?? "";
        try {
          await navigator.clipboard.writeText(text);
          const prev = btn.textContent;
          btn.textContent = "copied";
          btn.classList.add("copied");
          setTimeout(() => {
            btn.textContent = prev;
            btn.classList.remove("copied");
          }, 1400);
        } catch {
          /* clipboard unavailable */
        }
      });
    </script>
  </body>
</html>
